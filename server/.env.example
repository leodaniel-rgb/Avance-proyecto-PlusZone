# Supabase (PostgreSQL) - Conexión directa
# Obtén la URI en: Supabase → Project Settings → Database → Connection string → Direct connection
# Formato: postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[Admin#PlisZone]@db.xxxx.supabase.co:5432/postgres

# Supabase Auth (verificación de correo sin SMTP; Supabase envía el email)
# Project Settings → API: Project URL = SUPABASE_URL, anon public = SUPABASE_ANON_KEY
# JWT Secret: Project Settings → API → JWT Secret (para validar tokens en /api/auth/session)
SUPABASE_URL=https://qobjulqrwrxachoyjqgn.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFvYmp1bHFyd3J4YWNob3lqcWduIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEyNjQzOTEsImV4cCI6MjA4Njg0MDM5MX0.oafxjUwisPCLmYJMjcyZlFad-JyfNuP6zpNuuoLxqLg
SUPABASE_JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFvYmp1bHFyd3J4YWNob3lqcWduIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEyNjQzOTEsImV4cCI6MjA4Njg0MDM5MX0.oafxjUwisPCLmYJMjcyZlFad-JyfNuP6zpNuuoLxqLg

# Email (SMTP) - flujo principal de verificación por código (7 dígitos)
# Ejemplo con Brevo (Sendinblue):
#  - Host: smtp-relay.brevo.com
#  - Puerto: 587
#  - Seguridad: false (STARTTLS)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_user       # NO lo subas al repositorio
EMAIL_PASS=your_smtp_pass       # NO lo subas al repositorio
EMAIL_FROM=PlusZone@tu-dominio.com
EMAIL_FALLBACK=true

# Si es "false", se omite el flujo de API HTTP del proveedor y se usa solo SMTP (recomendado)
EMAIL_API_ENABLED=false

# Puerto del servidor
PORT=4000

# Código de verificación (7 dígitos, flujo legacy): duración en minutos
VERIFICATION_EXPIRATION_MINUTES=15

